# ─────────────────────────────────────────────────────────────
# Streamlit Community Cloud 배포용 시크릿 템플릿
# 이 파일을 secrets.toml 로 복사하지 말고, 값만 복사해서
# share.streamlit.io → 앱 → Settings → Secrets 에 붙여넣으세요.
# (실제 secrets.toml 은 .gitignore 로 커밋이 차단됩니다)
# ─────────────────────────────────────────────────────────────

# ── 공개 배포용 비밀번호 게이트 ──
# 앱을 "Anyone with the link"(공개)로 열 때 반드시 설정하세요.
# 설정하지 않으면 앱이 열리지 않습니다(무방비 노출 방지). 링크+이 비밀번호를 아는
# 사람만 사용할 수 있습니다. 내부용(초대 전용)으로만 쓸 거면 비워둬도 됩니다.
APP_PASSWORD = ""

# 최소 1개 필요. 없는 프로바이더는 자동 비활성화됩니다.
ANTHROPIC_API_KEY = ""
OPENAI_API_KEY = ""
GOOGLE_API_KEY = ""

# (선택) 모델 오버라이드
# ANTHROPIC_MODEL = "claude-opus-4-8"
# OPENAI_MODEL = "gpt-5"
# GEMINI_MODEL = "gemini-2.5-pro"

# (선택) 외부 PPT 디자인 엔진
# GAMMA_API_KEY = ""
# CANVA_ACCESS_TOKEN = ""
# 참고: Google Slides 엔진은 서비스계정 '파일 경로'가 필요해
#      클라우드 배포에서는 사용이 제한됩니다(로컬 실행 권장).
