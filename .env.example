# 이 파일을 .env 로 복사한 뒤 실제 API 키를 입력하세요.
# 키가 없는 프로바이더는 자동으로 비활성화됩니다 (최소 1개 필요).

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI GPT — https://platform.openai.com/
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/
GOOGLE_API_KEY=

# (선택) 모델 오버라이드 — 비워두면 기본값 사용
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-5
# GEMINI_MODEL=gemini-2.5-pro

# ─── PPT 디자인 엔진 (선택 — 키를 넣으면 해당 엔진이 활성화됨) ───

# Gamma — https://gamma.app (Pro 이상 플랜에서 Account Settings > API Keys)
GAMMA_API_KEY=

# Canva — https://www.canva.dev/docs/connect/ 앱 등록 후 OAuth 액세스 토큰
CANVA_ACCESS_TOKEN=

# Google Slides — GCP 서비스 계정 JSON 키 파일의 경로 (Slides+Drive API 활성화 필요)
GOOGLE_SERVICE_ACCOUNT_FILE=
# GOOGLE_SLIDES_SHARE_ROLE=writer   # reader 로 바꾸면 열람 전용 공유
